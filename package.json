{
  "name": "beru",
  "version": "1.6.29",
  "description": "Beru",
  "main": "main/main.js",
  "type": "module",
  "author": "Beru",
  "homepage": "https://beru.app",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build && electron-builder",
    "build:processor": "node scripts/build-processor.mjs",
    "preview": "vite preview",
    "start": "electron .",
    "test": "vitest run",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fetch:ffmpeg": "node scripts/fetch-ffmpeg.mjs",
    "postinstall": "node scripts/fetch-ffmpeg.mjs || node -e \"console.warn('[ffmpeg] postinstall skipped (deps not installed yet)')\""
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.7",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.32",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0"
  },
  "build": {
    "appId": "app.beru.desktop",
    "productName": "Beru",
    "copyright": "Copyright © 2026 Beru",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "main/**/*",
      "build/**/*",
      "resources/**/*",
      "!python/build/**",
      "!python/dist/**",
      "!python/__pycache__/**"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "processor.py",
          "batch_errors.py",
          "encode_profiles.py",
          "!build/**",
          "!dist/**",
          "!__pycache__/**",
          "!test_*.py"
        ]
      },
      {
        "from": "bin",
        "to": "bin"
      },
      {
        "from": "resources/presets",
        "to": "presets"
      },
      {
        "from": "resources/encode-profiles.json",
        "to": "encode-profiles.json"
      }
    ],
    "win": {
      "icon": "brand/icon.ico",
      "artifactName": "Beru-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signtoolOptions": {
        "publisherName": "Beru"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "es_ES"
      ],
      "uninstallDisplayName": "Beru ${version}",
      "shortcutName": "Beru"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "alphagiolabs",
        "repo": "beru",
        "releaseType": "release"
      }
    ]
  }
}
