{
  "name": "beru",
  "version": "1.6.45",
  "description": "Beru",
  "main": "main/main.js",
  "type": "module",
  "author": "Beru",
  "homepage": "https://beru.app",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build && electron-builder",
    "build:processor": "node scripts/build-processor.mjs",
    "preview": "vite preview",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:python": "python python/test_delogo.py && python python/test_delogo_robust.py && python python/test_text_layout_fixtures.py",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fetch:ffmpeg": "node scripts/fetch-ffmpeg.mjs",
    "postinstall": "node scripts/fetch-ffmpeg.mjs || node -e \"console.warn('[ffmpeg] postinstall skipped (deps not installed yet)')\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "globals": "^15.14.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.32",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "app.beru.desktop",
    "productName": "Beru",
    "copyright": "Copyright © 2026 Beru",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "main/**/*",
      "shared/**/*",
      "build/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*",
      "node_modules/sax/**/*",
      "node_modules/argparse/**/*",
      "node_modules/graceful-fs/**/*",
      "resources/**/*",
      "!python/build/**",
      "!python/dist/**",
      "!python/__pycache__/**"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin"
      },
      {
        "from": "resources/presets",
        "to": "presets"
      },
      {
        "from": "resources/encode-profiles.json",
        "to": "encode-profiles.json"
      }
    ],
    "win": {
      "icon": "brand/icon.ico",
      "artifactName": "Beru-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "verifyUpdateCodeSignature": false
    },
    "beforeBuild": "scripts/build-processor.hook.cjs",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "es_ES"
      ],
      "uninstallDisplayName": "Beru ${version}",
      "shortcutName": "Beru"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "alphagiolabs",
        "repo": "beru",
        "releaseType": "release"
      }
    ]
  }
}
