{
  "name": "beru",
  "version": "1.5.4",
  "description": "Beru — Editor de video masivo con overlays de texto vía base de datos Excel",
  "main": "main/main.js",
  "type": "module",
  "author": "Beru",
  "homepage": "https://beru.app",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "start": "electron .",
    "test": "vitest run",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-updater": "^6.8.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.4.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "app.beru.desktop",
    "productName": "Beru",
    "copyright": "Copyright © 2026 Beru",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "main/**/*",
      "build/**/*",
      "python/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python"
      },
      {
        "from": "src-tauri/bin",
        "to": "bin"
      },
      {
        "from": "resources/presets",
        "to": "presets"
      }
    ],
    "win": {
      "icon": "brand/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "Beru"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "es_ES"
      ],
      "uninstallDisplayName": "Beru ${version}",
      "shortcutName": "Beru"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "alphagiolabs",
        "repo": "beru",
        "releaseType": "release"
      }
    ]
  }
}
