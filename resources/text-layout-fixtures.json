{
  "version": 1,
  "_comment": "Test contract for CSS preview ↔ FFmpeg export layout math. Not runtime config. Keep JS (src/utils/text-layout.js) and Python (text_layout_helpers.py) in sync.",
  "bounds_cases": [
    {
      "id": "safe-and-box-pad",
      "region": { "x": 100, "y": 200, "w": 400, "h": 80 },
      "safe_margin": 4,
      "op": { "bg_enabled": true, "box_border_width": 8 },
      "expected": {
        "box_pad": 8,
        "bounds": { "x": 112, "y": 212, "w": 376, "h": 56 }
      }
    },
    {
      "id": "bg-off-no-box-pad",
      "region": { "x": 100, "y": 200, "w": 400, "h": 80 },
      "safe_margin": 4,
      "op": { "bg_enabled": false, "box_border_width": 8 },
      "expected": {
        "box_pad": 0,
        "bounds": { "x": 104, "y": 204, "w": 392, "h": 72 }
      }
    },
    {
      "id": "default-box-pad",
      "region": { "x": 0, "y": 0, "w": 200, "h": 50 },
      "safe_margin": 0,
      "op": { "bg_enabled": true },
      "expected": {
        "box_pad": 4,
        "bounds": { "x": 4, "y": 4, "w": 192, "h": 42 }
      }
    },
    {
      "id": "inset-clamps-to-zero",
      "region": { "x": 10, "y": 10, "w": 5, "h": 5 },
      "safe_margin": 4,
      "op": { "bg_enabled": true, "box_border_width": 4 },
      "expected": {
        "box_pad": 4,
        "bounds": { "x": 18, "y": 18, "w": 0, "h": 0 }
      }
    },
    {
      "id": "string-bg-false",
      "region": { "x": 50, "y": 50, "w": 300, "h": 100 },
      "safe_margin": 2,
      "op": { "bg_enabled": "false", "box_border_width": 6 },
      "expected": {
        "box_pad": 0,
        "bounds": { "x": 52, "y": 52, "w": 296, "h": 96 }
      }
    }
  ],
  "wrap_cases": [
    {
      "id": "short-no-wrap",
      "text": "hello",
      "max_width_px": 500,
      "font_size": 32,
      "expected": { "wrapped": "hello" }
    },
    {
      "id": "long-wrap",
      "text": "one two three four five six",
      "max_width_px": 80,
      "font_size": 32,
      "expected": { "wrapped": "one\ntwo\nthree\nfour\nfive\nsix" }
    },
    {
      "id": "multiline-preserve",
      "text": "aaa\nbbb",
      "max_width_px": 500,
      "font_size": 32,
      "expected": { "wrapped": "aaa\nbbb" }
    }
  ]
}
